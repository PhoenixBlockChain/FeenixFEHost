# Feenix FE Host Configuration

# Where extracted frontend files are stored
APPS_DIR=./apps

# State file tracking deployed apps
STATE_FILE=./state.json

# Polling interval in milliseconds (60s)
POLL_INTERVAL=60000

# Blockchain API
BLOCKCHAIN_API_URL=http://api.feenix.network

# Nginx apps root (for production — must match nginx.conf)
NGINX_APPS_ROOT=/var/www/apps
